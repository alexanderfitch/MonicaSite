---
import BaseLayout from '../layouts/BaseLayout.astro';
import Newsletter from '../components/Newsletter.astro';
import PullQuote from '../components/PullQuote.astro';

const heroQuotes = [
  'Every family has a story. Not every family tells the truth.',
  'She could carry the name. She would not carry the lie.',
  'Some stories protect a family. Some protect the people who harmed it.',
  'Starting over is not failure. It is the most courageous act available to a woman who finally knows herself.',
];
---

<BaseLayout active="home">
  <!-- HERO (Card 1) -->
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Author &middot; Debut Novel</p>
        <h1>Every family has a story. Not every family tells the truth.</h1>
        <p class="lede">
          Monica Messer writes fiction about women at the moment they stop managing
          everyone else's story and begin telling the truth about their own. Her debut novel,
          <em>The Family Narrative</em>, explores marriage, money, motherhood, reputation,
          female friendship, and the quiet cost of looking away.
        </p>
        <div class="btn-group">
          <a href="/the-family-narrative/" class="btn btn-primary">Explore The Family Narrative</a>
          <a href="/newsletter/" class="btn btn-outline">Join My Newsletter</a>
        </div>
      </div>
      <div class="hero-media">
        <img src="/assets/author-portrait.jpg" alt="Portrait of author Monica Messer" class="portrait" />
        <div class="book-chip">
          <img src="/assets/book-cover.png" alt="The Family Narrative book cover" />
          <div>
            <div class="label">Debut Novel</div>
            <div class="title">The Family Narrative</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- DEBUT NOVEL FEATURE (Cards 2 + 11) -->
  <section class="bg-sand">
    <div class="container split">
      <div class="split-media">
        <img src="/assets/book-cover.png" alt="The Family Narrative by Monica Messer" class="cover-img" />
      </div>
      <div class="split-copy">
        <p class="eyebrow">Debut Novel</p>
        <h2>The Family Narrative</h2>
        <p>
          For decades, Frances Stanton has lived inside a family story everyone else admired:
          a respected husband, accomplished sons, university circles, philanthropic events, and
          a name that meant success, loyalty, and legacy. Then Dick files for divorce.
        </p>
        <p>
          At first, Frances believes the end of her marriage is the crisis she must survive.
          But as the polished Stanton narrative begins to crack, she discovers what the family
          has protected, what the institution has minimized, and what it has cost her to keep
          looking away.
        </p>
        <div class="btn-group">
          <a href="/the-family-narrative/" class="btn btn-primary">Read About the Novel</a>
        </div>
      </div>
    </div>
  </section>

  <!-- INSIDE THE NOVEL — condensed themes (Card 5) -->
  <section>
    <div class="container">
      <div class="section-head center">
        <p class="eyebrow">Inside the Novel</p>
        <h2>The questions at its center</h2>
      </div>
      <div class="grid-cards">
        <div class="theme-card">
          <h3>Marriage &amp; reputation</h3>
          <p>What does a wife owe a marriage once the truth is no longer private?</p>
        </div>
        <div class="theme-card">
          <h3>Motherhood &amp; moral clarity</h3>
          <p>Frances's sons force her to see what adults have been willing to minimize.</p>
        </div>
        <div class="theme-card">
          <h3>Truth &amp; reinvention</h3>
          <p>Starting over begins with saying what is real.</p>
        </div>
      </div>
      <div class="center" style="margin-top:40px;">
        <a href="/the-family-narrative/" class="btn btn-outline">See all the themes</a>
      </div>
    </div>
  </section>

  <!-- READER PROMISE (Card 6) -->
  <section class="bg-sand2">
    <div class="container narrow center">
      <p class="eyebrow">Is this novel for you?</p>
      <h2>For readers who love emotionally honest fiction about women's lives after the performance stops.</h2>
      <p class="lede measure">
        <em>The Family Narrative</em> is for readers drawn to domestic literary fiction,
        complicated marriages, family systems, moral reckonings, women in midlife,
        mother-son relationships, financial awakening, and the kind of friendship that
        tells the truth even when it hurts.
      </p>
      <div class="btn-group center">
        <a href="/newsletter/" class="btn btn-primary">Get Book Updates</a>
      </div>
    </div>
  </section>

  <!-- PULL QUOTE (Card 8) — rotating -->
  <PullQuote quotes={heroQuotes} />

  <!-- AUTHOR CONNECTION (Card 9) -->
  <section class="bg-slate">
    <div class="container split reverse">
      <div class="split-copy">
        <p class="eyebrow" style="color:#C9A96B;">The Author</p>
        <h2>From building companies to telling the truth about women's lives.</h2>
        <p>
          For decades, Monica Messer built, led, managed, and measured success. Now her writing
          turns toward what does not show up on a balance sheet: the quiet decisions, hidden costs,
          and private reckonings that shape a woman's life. <em>The Family Narrative</em> grows out
          of that same inquiry — what we choose not to see, what it costs to keep performing, and
          what becomes possible when we finally look.
        </p>
        <div class="btn-group">
          <a href="/about/" class="btn btn-light">About Monica</a>
        </div>
      </div>
      <div class="split-media">
        <img src="/assets/author-portrait.jpg" alt="Monica Messer" class="cover-img" style="filter:grayscale(100%); max-width:300px;" />
      </div>
    </div>
  </section>

  <Newsletter />
</BaseLayout>
