---
import BaseLayout from '../layouts/BaseLayout.astro';
import Newsletter from '../components/Newsletter.astro';
import PullQuote from '../components/PullQuote.astro';

const heroQuotes = [
  'Every family has a story. Not every family tells the truth.',
  'She could carry the name. She would not carry the lie.',
  'Some stories protect a family. Some protect the people who harmed it.',
  'Starting over is not failure. It is the most courageous act available to a woman who finally knows herself.',
];

// The work, distilled — the ideas Monica returns to again and again.
const values = [
  {
    title: 'Truth',
    body: 'Everything I write begins here: helping women see what they have been trained not to look at.',
  },
  {
    title: 'Clarity',
    body: 'Seeing things as they are — not as we were taught, promised, or pressured to see them — is the beginning of every good decision.',
  },
  {
    title: 'Financial Awareness',
    body: 'Money is not a dirty word. Silence around it can be devastating. Women deserve full, honest knowledge of their financial lives.',
  },
  {
    title: 'Courage',
    body: 'Not the loud kind. The quiet, daily courage to name what is true, leave what no longer fits, and begin again.',
  },
  {
    title: 'Friendship',
    body: 'The women worth keeping are the ones who can comfort you without helping you hide.',
  },
  {
    title: 'Reinvention',
    body: 'Starting over is not failure. Sometimes it is the first honest decision a woman gets to make for herself.',
  },
];
---

<BaseLayout active="home" bodyClass="home-dark">
  <!-- HERO (Card 1) -->
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Author &middot; Debut Novel</p>
        <p class="lede">
          Monica Messer writes emotionally rich fiction about women, families, reputation,
          reinvention, and the stories people inherit before they learn how to question them.
        </p>
        <p>
          After more than forty years in leadership roles, Monica brings a deep interest in power,
          perception, decision-making, and personal reinvention to her fiction. She lives in Omaha,
          Nebraska, with her husband, and regularly spends time writing in Los Angeles and Belize.
        </p>
        <p>
          Her debut novel, <em>The Family Narrative</em>, explores marriage, motherhood, money,
          legacy, and one woman's decision to stop protecting a story that was never fully hers.
        </p>
        <div class="btn-group">
          <a href="/the-family-narrative/" class="btn btn-primary">Explore The Family Narrative</a>
          <a href="/newsletter/" class="btn btn-outline">Join My Newsletter</a>
        </div>
      </div>
      <div class="hero-media">
        <img src="/assets/author-portrait.jpg" alt="Portrait of author Monica Messer" class="portrait" />
      </div>
    </div>
  </section>

  <!-- DEBUT NOVEL FEATURE (Cards 2 + 11) -->
  <section class="bg-sand">
    <div class="container split">
      <div class="split-media">
        <img src="/assets/book-cover.png" alt="The Family Narrative by Monica Messer" class="cover-img" />
      </div>
      <div class="split-copy">
        <p class="eyebrow">Debut Novel</p>
        <h2>The Family Narrative</h2>
        <p>
          Her debut novel, <em>The Family Narrative</em>, explores marriage, motherhood, money,
          legacy, and one woman's decision to stop protecting a story that was never fully hers.
        </p>
        <p>
          For decades, Frances Stanton has lived inside a family story everyone else admired —
          a respected husband, accomplished sons, university circles, and a name that meant success
          and legacy. Then Dick files for divorce, and the polished Stanton narrative begins to crack.
        </p>
        <div class="btn-group">
          <a href="/the-family-narrative/" class="btn btn-primary">Read About the Novel</a>
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT THE WORK IS ABOUT — values (anchor line + cards) -->
  <section>
    <div class="container">
      <div class="section-head center">
        <p class="eyebrow">What the work is about</p>
        <h2>Helping women see what they have been trained not to look at.</h2>
      </div>
      <div class="grid-cards values-cards">
        {values.map((v) => (
          <div class="theme-card">
            <h3>{v.title}</h3>
            <p>{v.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- READER PROMISE (Card 6) -->
  <section class="bg-sand2">
    <div class="container narrow center">
      <p class="eyebrow">Is this novel for you?</p>
      <h2>For readers who love emotionally honest fiction about women's lives after the performance stops.</h2>
      <p class="lede measure">
        <em>The Family Narrative</em> is for readers drawn to domestic literary fiction,
        complicated marriages, family systems, moral reckonings, women in midlife,
        mother-son relationships, financial awakening, and the kind of friendship that
        tells the truth even when it hurts.
      </p>
      <div class="btn-group center">
        <a href="/newsletter/" class="btn btn-primary">Get Book Updates</a>
      </div>
    </div>
  </section>

  <!-- PULL QUOTE (Card 8) — rotating -->
  <PullQuote quotes={heroQuotes} />

  <!-- AUTHOR CONNECTION (Card 9) -->
  <section class="bg-slate">
    <div class="container split reverse">
      <div class="split-copy">
        <p class="eyebrow" style="color:#C9A96B;">The Author</p>
        <h2>Forty years in leadership — and a deep interest in power and reinvention.</h2>
        <p>
          After more than forty years in leadership roles, Monica brings a deep interest in power,
          perception, decision-making, and personal reinvention to her fiction. She lives in Omaha,
          Nebraska, with her husband, and regularly spends time writing in Los Angeles and Belize.
        </p>
        <div class="btn-group">
          <a href="/about/" class="btn btn-light">About Monica</a>
        </div>
      </div>
      <div class="split-media">
        <img src="/assets/author-portrait.jpg" alt="Monica Messer" class="cover-img" style="filter:grayscale(100%); max-width:300px;" />
      </div>
    </div>
  </section>

  <Newsletter />
</BaseLayout>
