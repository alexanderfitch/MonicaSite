---
// Reusable newsletter signup block (Card 10).
// Placeholder form — see README for wiring to a real provider.
---

<section class="newsletter">
  <div class="container">
    <div class="inner">
      <p class="eyebrow">Stay close to the work</p>
      <h2>Join Monica's newsletter</h2>
      <p>
        Honest writing about reinvention, clarity, money, truth, and the courage to start over —
        plus updates on <em>The Family Narrative</em>. No noise. Just ideas worth sitting with.
      </p>
      <form class="nl-form" novalidate>
        <input type="text" name="name" placeholder="Name" aria-label="Name" />
        <input type="email" name="email" placeholder="Email" aria-label="Email" required />
        <button type="submit" class="btn btn-primary">Subscribe</button>
      </form>
      <p class="nl-micro">No spam, ever. Unsubscribe anytime.</p>
      <div class="nl-success"></div>
    </div>
  </div>
</section>
